# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Ambiente virtuale (ogni clone ricrea venv + pip install)
.venv/
venv/
.env
.env.*

# Dati sensibili e generati — cartella sincronizzata (Dropbox): non versionare mai chiavi né DB cifrati
data/**/*.enc
data/**/*.key
data/**/*.json

# Import legacy e sessione pre-login (fuori da `data/`, vedi `main_app` / `import_legacy`)
legacy_import/*.json
legacy_import/*.enc

# macOS / Finder
.DS_Store
**/.DS_Store

# Cursor / log di debug locale
.cursor/debug*.log

# PyInstaller (scripts/build_macos_app.sh, scripts/build_windows_app.ps1)
build/
dist/
